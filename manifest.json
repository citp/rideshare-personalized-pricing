{
  "manifest_version": 3,
  "name": "Uber Personalized Prices Aggregator",
  "version": "2.0",
  "permissions": ["storage", "tabs", "alarms", "notifications", "cookies", "history", "management"],
  "host_permissions": ["https://m.uber.com/*", "https://riders.uber.com/*"],
  "background": {
    "service_worker": "background/background-entry.js"
  },
  "content_scripts": [
    {
      "matches": ["https://m.uber.com/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://m.uber.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://riders.uber.com/*"],
      "js": ["content/trip-history-content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
